{
  "name": "questlog",
  "version": "1.0.0",
  "description": "Quest Log — Game Backlog Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "author": "QuestLog Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.questlog.app",
    "productName": "Quest Log",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "weeever",
      "repo": "Game-tracker"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "app.js",
      "icon.png",
      "icon.ico",
      "overlay.html",
      "overlay.css"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Quest Log",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.3.9"
  }
}
